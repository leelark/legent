{
  "title": "Legent Email Studio Overview",
  "uid": "legent-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP p95 latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (le, application))",
          "legendFormat": "{{application}}"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "HTTP 5xx rate",
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) by (application)",
          "legendFormat": "{{application}}"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Pod restarts",
      "targets": [
        {
          "expr": "increase(kube_pod_container_status_restarts_total{namespace=\"legent\"}[30m])",
          "legendFormat": "{{pod}}"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Kafka lag",
      "targets": [
        {
          "expr": "kafka_consumer_fetch_manager_records_lag_max",
          "legendFormat": "{{client_id}}"
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Executor saturation",
      "targets": [
        {
          "expr": "max(legent_executor_saturation_ratio{namespace=\"legent\"}) by (application, executor)",
          "legendFormat": "{{application}} {{executor}}"
        }
      ],
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "OpenTelemetry collector health",
      "targets": [
        {
          "expr": "up{job=~\".*otel.*\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Outbox ready depth",
      "targets": [
        {
          "expr": "max(legent_outbox_ready_depth{queue=~\"tracking|delivery_feedback\"}) by (queue)",
          "legendFormat": "{{queue}}"
        }
      ],
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Outbox oldest ready age",
      "targets": [
        {
          "expr": "max(legent_outbox_oldest_ready_age_seconds{queue=~\"tracking|delivery_feedback\"}) by (queue)",
          "legendFormat": "{{queue}}"
        }
      ],
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Retry ready depth",
      "targets": [
        {
          "expr": "max(legent_retry_ready_depth{queue=~\"campaign_partial_batches|campaign_stale_processing_batches|delivery_scheduled_messages\"}) by (queue)",
          "legendFormat": "{{queue}}"
        }
      ],
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Retry oldest ready age",
      "targets": [
        {
          "expr": "max(legent_retry_oldest_ready_age_seconds{queue=~\"campaign_partial_batches|campaign_stale_processing_batches|delivery_scheduled_messages\"}) by (queue)",
          "legendFormat": "{{queue}}"
        }
      ],
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "DLQ depth",
      "targets": [
        {
          "expr": "max(legent_dlq_depth{source=~\"campaign_dead_letters|delivery_failed_messages\"}) by (source)",
          "legendFormat": "{{source}}"
        }
      ],
      "gridPos": { "x": 0, "y": 40, "w": 8, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "DLQ oldest age",
      "targets": [
        {
          "expr": "max(legent_dlq_oldest_age_seconds{source=~\"campaign_dead_letters|delivery_failed_messages\"}) by (source)",
          "legendFormat": "{{source}}"
        }
      ],
      "gridPos": { "x": 8, "y": 40, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "DLQ skew",
      "targets": [
        {
          "expr": "max(legent_dlq_skew_ratio{source=~\"campaign_dead_letters|delivery_failed_messages\"}) by (source)",
          "legendFormat": "{{source}}"
        }
      ],
      "gridPos": { "x": 16, "y": 40, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      }
    }
  ]
}
